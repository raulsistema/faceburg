# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# AUTH_SECRET: Required in production to sign tenant/admin sessions securely.
# Use a long random string, for example generated with openssl rand -base64 32
AUTH_SECRET="CHANGE_ME_LONG_RANDOM_SECRET"

# PostgreSQL connection (local/dev)
DB_HOST="faceburg.postgres.uhserver.com"
DB_PORT="5432"
DB_NAME="faceburg"
DB_USER="faceburg"
DB_PASSWORD="YOUR_DB_PASSWORD"
DB_SSL="false"

# Roteamento/geocoding da taxa por km
# OSRM_ROUTE_URL aceita servidor proprio ou compativel com a API do OSRM.
# Se nao definir, o sistema usa https://router.project-osrm.org como padrao.
OSRM_ROUTE_URL="https://router.project-osrm.org"
OSRM_ROUTE_PROFILE="driving"
NOMINATIM_CONTACT_EMAIL="seu-email@dominio.com"

# Master admin credentials (login: /master/login)
MASTER_ADMIN_EMAIL="master@faceburg.com"
MASTER_ADMIN_PASSWORD="CHANGE_ME_MASTER_PASSWORD"

# Printer Agent (executado no PC da loja)
PRINT_SERVER_URL="http://localhost:3000"
PRINT_AGENT_KEY=""
PRINTER_NAME=""
PRINT_POLL_INTERVAL_MS="30000"
PRINT_POLL_FALLBACK_MS="20000"
PRINT_POLL_CONNECTED_SYNC_MS="300000"
PRINT_WS_RECONNECT_MS="3000"
PRINT_AUTH_BACKOFF_MS="60000"
PRINT_HEARTBEAT_MS="45000"
PRINT_AGENT_LOCK_PORT="49332"

# WhatsApp Agent (executado no PC da loja)
WHATS_SERVER_URL="http://localhost:3000"
WHATS_AGENT_KEY=""
WHATS_SLUG=""
WHATS_EMAIL=""
WHATS_PASSWORD=""
WHATS_CLIENT_ID=""
WHATS_DATA_DIR=""
WHATS_POLL_INTERVAL_MS="2500"
WHATS_HEADLESS="false"
WHATS_CHROME_PATH=""
WHATS_AGENT_LOCK_PORT="49331"
WHATS_RESTART_DELAY_MS="5000"
WHATS_INIT_TIMEOUT_MS="120000"
WHATS_WATCHDOG_INTERVAL_MS="30000"
WHATS_POLL_FALLBACK_MS="25000"
WHATS_POLL_CONNECTED_SYNC_MS="300000"
WHATS_WS_RECONNECT_MS="3000"
WHATS_AUTH_BACKOFF_MS="60000"
WHATS_HEARTBEAT_MS="45000"

# Gateway realtime (push de jobs para os agentes)
REALTIME_GATEWAY_HOST="0.0.0.0"
REALTIME_GATEWAY_PORT="3001"
REALTIME_WS_PORT="3001"
REALTIME_WS_PATH="/ws/agents"
# Opcional para agentes apontarem para endpoint WS especifico
# REALTIME_WS_URL="ws://localhost:3001/ws/agents"
