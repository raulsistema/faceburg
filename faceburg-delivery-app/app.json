{
  "expo": {
    "name": "Faceburg Entregador",
    "slug": "faceburg-entregador",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "faceburg-entregador",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "android": {
      "package": "com.rbs.faceburg.entregador",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "POST_NOTIFICATIONS"
      ]
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rbs.faceburg.entregador",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Usamos a localizacao para acompanhar entregas ativas.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Usamos a localizacao em segundo plano apenas durante entregas ativas."
      }
    },
    "extra": {
      "apiBaseUrl": "$EXPO_PUBLIC_API_BASE_URL",
      "expoProjectId": "$EXPO_PROJECT_ID"
    }
  }
}
