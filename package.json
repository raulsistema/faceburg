{
  "name": "ai-studio-applet",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev-local.mjs",
    "dev:app": "next dev -p 3000",
    "dev:realtime": "node realtime-gateway.js",
    "build": "node scripts/clean-next.mjs && next build && node scripts/prepare-standalone.mjs",
    "start": "node scripts/start-standalone.mjs",
    "lint": "eslint .",
    "clean": "node scripts/clean-next.mjs",
    "typecheck": "node scripts/clean-next.mjs && next typegen && tsc --noEmit",
    "realtime:gateway": "node realtime-gateway.js",
    "app:install": "npm --prefix faceburg-hub install",
    "app:start": "npm --prefix faceburg-hub start",
    "app:dist": "npm --prefix faceburg-hub run dist",
    "app:dist:portable": "npm --prefix faceburg-hub run dist:portable",
    "hub:install": "npm --prefix faceburg-hub install",
    "hub:start": "npm --prefix faceburg-hub start",
    "hub:dist": "npm --prefix faceburg-hub run dist",
    "hub:dist:portable": "npm --prefix faceburg-hub run dist:portable"
  },
  "dependencies": {
    "@google/genai": "^1.17.0",
    "@hookform/resolvers": "^5.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "autoprefixer": "^10.4.21",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.553.0",
    "motion": "^12.23.24",
    "next": "15.5.15",
    "pg": "^8.20.0",
    "postcss": "^8.5.6",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwind-merge": "^3.5.0",
    "whatsapp-web.js": "^1.34.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "9.39.1",
    "eslint-config-next": "15.5.15",
    "firebase-tools": "^15.0.0",
    "tailwindcss": "4.1.11",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3"
  }
}
